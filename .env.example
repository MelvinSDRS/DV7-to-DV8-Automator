# Copy to .env and adjust values for your environment.
# The scripts auto-load .env from repository root unless DV8_ENV_FILE is set.
# This file is sourced by bash, so variable expansion/command substitution is supported.

# Base paths
DV8_BASE_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" &>/dev/null && pwd)"
DV8_SCRIPT_PATH="${DV8_BASE_DIR}/DV7toDV8.sh"

# Converter behavior
DV8_EL_RPU_DIR=/NAS/EL_RPU
DV8_PROCESSING_LOG_FILE="${DV8_BASE_DIR}/processing_log.txt"
DV8_CONVERTER_BIN=

# qBittorrent wrapper behavior
DV8_TRIGGER_LOG_FILE="${DV8_BASE_DIR}/qbt_trigger.log"
DV8_TRIGGER_LOG_MAX_BYTES=10485760
DV8_RUN_DIR=/tmp/dv8-qbt
DV8_AUTORUN_DRY_RUN=false
DV8_MAX_PARALLEL_JOBS=1
DV8_QUEUE_WAIT_SECONDS=15
DV8_JOB_LOG_RETENTION_DAYS=30

# qBittorrent API and cleanup
DV8_QBT_API_URL=http://127.0.0.1:8080
DV8_QBT_REMOVE_CONVERTED=true

# Roots scanned to repoint hardlinks after conversion
DV8_MEDIA_ROOTS=/path/to/media/root1:/path/to/media/root2
